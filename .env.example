LLM_BASE_URL=http://127.0.0.1:8080
LLM_COMPLETION_ENDPOINT=/completion
LLM_TIMEOUT_SECONDS=600
LLM_MAX_TOKENS=256
LLM_CHAT_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2

LLAMA_MODEL_FILE=MiniCPM5-1B-Q4_K_M.gguf
LLAMA_MODEL_URL=https://huggingface.co/openbmb/MiniCPM5-1B-GGUF/resolve/main/MiniCPM5-1B-Q4_K_M.gguf
# Previous Qwen model:
# LLAMA_MODEL_FILE=Qwen2.5-3B-Instruct-Q4_K_M.gguf
# LLAMA_MODEL_URL=https://huggingface.co/bartowski/Qwen2.5-3B-Instruct-GGUF/resolve/main/Qwen2.5-3B-Instruct-Q4_K_M.gguf
LLAMA_THREADS=1
LLAMA_CONTEXT_SIZE=4096
LLAMA_PARALLEL=1
LLAMA_MAX_TOKENS=1024
LLAMA_SERVER_PORT=8080

SERVICE_NAME=document-generation-api
DEPLOYMENT_ENVIRONMENT=local
LOG_LEVEL=INFO

OTEL_ENABLED=true
OTEL_TRACES_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

APP_LOG_FRONTEND_MESSAGES=true
APP_LOG_RESPONSE_BODY=true
APP_LOG_LLM_RAW=false
APP_LOG_DEBUG_PAYLOADS=false
APP_LOG_MAX_FIELD_LENGTH=2000

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
